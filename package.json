{
  "name": "qa-automation-suite",
  "version": "1.0.0",
  "description": "QA Automation portfolio project — Demoblaze e-commerce testing",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=chromium",
    "test:headed": "playwright test --project=chromium --headed",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "npm run allure:generate && npm run allure:open",
    "load": "k6 run load-test.k6.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "allure-js-commons": "^3.10.2",
    "zod": "^4.4.3"
  }
}
